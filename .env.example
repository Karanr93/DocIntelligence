# LLM API Keys (only needed if using groq or openai provider)
OPENAI_API_KEY=
GROQ_API_KEY=

# AWS Credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=document-clause-system

# LLM Provider: "bedrock", "groq", or "openai"
# bedrock = Claude Sonnet via AWS (data stays in your AWS account)
# groq = Llama via Groq (free, but data goes to Groq servers)
# openai = GPT via OpenAI (data goes to OpenAI servers)
LLM_PROVIDER=bedrock
LLM_MODEL=us.anthropic.claude-sonnet-4-20250514
BEDROCK_REGION=us-east-1

# Database
DATABASE_URL=sqlite:///./clause_system.db

# App
UPLOAD_DIR=./uploaded_pdfs
ANNOTATED_DIR=./annotated_pdfs
